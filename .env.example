#
# AgentTable — Environment Variables
#
# Copy this file to `.env` for local development, or set these in
# Easypanel → Service → Environment tab.
#

# ─── Network ──────────────────────────────────────────────────────
# Host port to bind (docker compose). Container listens on 8080 internally.
APP_PORT=8081

# ─── Database ─────────────────────────────────────────────────────
# SQLite path inside the container. The /data volume is mounted by compose.
DB_PATH=/data/application.db

# Python log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Admin auth ───────────────────────────────────────────────────
# Shared secret. When set, mutating endpoints (CSV-upload, delete) and the
# MCP write tools require the X-Admin-Key header. When unset, they are
# OPEN — do NOT run production without a key.
#
# Generate one with:  openssl rand -hex 32
#ADMIN_API_KEY=

# Company data: when true, MCP READS (tools/list + tools/call) also
# require X-Admin-Key. Recommended in production when /mcp is excluded
# from Cloudflare Access so the agent can reach it with just the key.
MCP_REQUIRE_KEY=true

# ─── Deploy webhook (local dev .env only — NOT an app setting) ────
# Easypanel's deploy webhook URL for this service. Lets the dev agent
# trigger a redeploy after pushing: curl -X POST $EASYPANEL_DEPLOY_WEBHOOK
# Rotate it in Easypanel if it leaks. The app itself never reads this.
#EASYPANEL_DEPLOY_WEBHOOK=
